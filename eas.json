{
  "cli": {
    "version": ">= 9.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "splitPerCpuArchitecture": true      }
    },
    "preview": {
      "distribution": "internal",
      "credentialsSource": "remote",
      "android": {
        "buildType": "apk",
        "splitPerCpuArchitecture": true      }
    },
    "production": {
      "android": {
        "buildType": "apk",
        "splitPerCpuArchitecture": true
      }
    }
  }
}
